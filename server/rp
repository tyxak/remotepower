#!/usr/bin/env bash
#
# rp — RemotePower node control (omd / checkmk style)
#
#   rp status              show every stack component + host service
#   rp tui                 live interactive dashboard (arrow keys + r/s/x/d/l)
#   rp start   [component] start the RemotePower stack (or one component)
#   rp stop    [component] stop it
#   rp restart [component] restart it
#   rp reload              reload nginx + restart the app server (config reload)
#   rp doctor              run health checks; exit non-zero on any failure
#   rp logs    [component] follow the journal for the stack (or one component)
#   rp install [args…]     (re)run install-server.sh from the source checkout
#   rp deploy  [args…]     run deploy-server.sh (update code + units + restart)
#   rp repair              make everything current again (re-deploy, or restart+reload)
#   rp version             print the installed server version
#   rp help                this help
#
# doctor/status are most accurate as root (they read the 0700 data dir + nginx
# config): use `sudo rp doctor`. install/deploy/repair auto-escalate with sudo.
#
# "Component" is one of the RemotePower-owned units without the leading
# `remotepower-` (e.g. `rp restart push`, `rp logs wsgi`). With no component the
# lifecycle verbs act on the whole stack.
#
# Lifecycle verbs need root (systemctl); status/doctor/version/logs do not.
# Installed by install-server.sh to /usr/local/bin/rp. Under Docker (no systemd)
# status/doctor still work via port/process probes; use `docker restart` for
# lifecycle.

set -uo pipefail

RP_DATA_DIR="${RP_DATA_DIR:-/var/lib/remotepower}"
RP_CODE_DIR="${RP_CODE_DIR:-/var/www/remotepower}"
MARKER="$RP_DATA_DIR/storage_backend.json"

# RemotePower-owned units, in start order. Optional ones may be absent.
UNITS=(remotepower-wsgi remotepower-scheduler remotepower-scanner remotepower-push remotepower-webterm)
# Host services shown in status but NOT touched by start/stop/restart (shared).
HOST_SVCS=(nginx)
# Loopback ports each component should be listening on (for probes).
declare -A PORT=( [remotepower-wsgi]=8090 [remotepower-push]=8766 [remotepower-webterm]=8765 )

# ── output helpers ────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  C_G=$'\033[32m'; C_R=$'\033[31m'; C_Y=$'\033[33m'; C_D=$'\033[2m'; C_B=$'\033[1m'; C_0=$'\033[0m'
else
  C_G=''; C_R=''; C_Y=''; C_D=''; C_B=''; C_0=''
fi
ok(){   printf '  %sOK%s   %s\n'   "$C_G" "$C_0" "$*"; }
warn(){ printf '  %sWARN%s %s\n'   "$C_Y" "$C_0" "$*"; }
fail(){ printf '  %sFAIL%s %s\n'   "$C_R" "$C_0" "$*"; }
info(){ printf '%s\n' "$*"; }

have_systemd(){ [ -d /run/systemd/system ] && command -v systemctl >/dev/null 2>&1; }
unit_file(){ systemctl list-unit-files "$1.service" >/dev/null 2>&1 && systemctl cat "$1.service" >/dev/null 2>&1; }
is_active(){ systemctl is-active --quiet "$1.service" 2>/dev/null; }
is_enabled(){ systemctl is-enabled --quiet "$1.service" 2>/dev/null; }
port_open(){ # $1 = port
  if command -v ss >/dev/null 2>&1; then ss -ltn 2>/dev/null | grep -q ":$1[[:space:]]"
  else (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null && { exec 3>&-; return 0; } || return 1
  fi
}
need_root(){ [ "$(id -u)" = 0 ] || { echo "rp $1 needs root — re-run with sudo." >&2; exit 1; }; }

# Resolve a user-typed component to a real unit ("push" → remotepower-push).
resolve_unit(){
  local c="$1"
  case "$c" in
    remotepower-*) printf '%s' "$c" ;;
    *)             printf 'remotepower-%s' "$c" ;;
  esac
}
# Which of UNITS are actually installed on this box.
installed_units(){
  local u; for u in "${UNITS[@]}"; do unit_file "$u" && printf '%s\n' "$u"; done
}

backend(){ # print json|sqlite|postgres|unknown from the marker
  # The data dir is 0700 (web user). A non-root/non-web caller can't traverse it
  # to read the marker — so fall back to the backend NAME the installers record in
  # the world-readable rp.env (they read the marker as root). The DSN is never in
  # there; only the harmless backend name. Last resort: 'unknown'.
  if [ ! -r "$RP_DATA_DIR" ] || [ ! -x "$RP_DATA_DIR" ]; then
    if [ -r /etc/remotepower/rp.env ]; then
      local b; b=$(. /etc/remotepower/rp.env 2>/dev/null; printf '%s' "${RP_BACKEND:-}")
      [ -n "$b" ] && { printf '%s' "$b"; return; }
    fi
    printf 'unknown'; return
  fi
  [ -f "$MARKER" ] || { printf 'json'; return; }
  python3 - "$MARKER" <<'PY' 2>/dev/null || printf 'unknown'
import json,sys
try: print((json.load(open(sys.argv[1])).get('backend') or 'json'))
except Exception: print('unknown')
PY
}
am_root(){ [ "$(id -u)" = 0 ]; }

server_version(){
  local v
  v=$(grep -oE "SERVER_VERSION\s*=\s*'[0-9][^']*'" "$RP_CODE_DIR/cgi-bin/api.py" 2>/dev/null | grep -oE "[0-9]+\.[0-9]+\.[0-9]+" | head -1)
  printf '%s' "${v:-unknown}"
}

# ── status ────────────────────────────────────────────────────────────────────
cmd_status(){
  info "${C_B}RemotePower${C_0} $(server_version)   backend=$(backend)   data=$RP_DATA_DIR"
  if ! have_systemd; then
    info "(no systemd — container mode; showing port/process probes)"
    local u p
    for u in "${UNITS[@]}"; do
      p="${PORT[$u]:-}"
      if [ -n "$p" ] && port_open "$p"; then ok "$u  (listening :$p)"
      elif pgrep -f "$u" >/dev/null 2>&1 || pgrep -f "${u#remotepower-}" >/dev/null 2>&1; then ok "$u  (process up)"
      else info "  ${C_D}····${C_0} $u  (not detected)"; fi
    done
    port_open 8090 && ok "nginx→app reachable" || warn "app (:8090) not reachable"
    return 0
  fi
  printf '  %-26s %-9s %-9s %s\n' "COMPONENT" "STATE" "BOOT" "PORT"
  local u state boot port pstat
  for u in "${UNITS[@]}"; do
    if ! unit_file "$u"; then
      printf '  %-26s %s%-9s%s %-9s %s\n' "$u" "$C_D" "absent" "$C_0" "-" "${C_D}not installed${C_0}"
      continue
    fi
    if is_active "$u"; then state="${C_G}running${C_0}"; else state="${C_R}stopped${C_0}"; fi
    if systemctl is-failed --quiet "$u.service" 2>/dev/null; then state="${C_R}FAILED${C_0}"; fi
    if is_enabled "$u"; then boot="enabled"; else boot="${C_Y}disabled${C_0}"; fi
    port="${PORT[$u]:-}"; pstat="-"
    if [ -n "$port" ]; then port_open "$port" && pstat="${C_G}:$port ✓${C_0}" || pstat="${C_R}:$port ✗${C_0}"; fi
    printf '  %-26s %-18b %-18b %b\n' "$u" "$state" "$boot" "$pstat"
  done
  local h
  for h in "${HOST_SVCS[@]}"; do
    if is_active "$h"; then printf '  %-26s %-18b %s\n' "$h ${C_D}(host)${C_0}" "${C_G}running${C_0}" ""
    else printf '  %-26s %-18b\n' "$h ${C_D}(host)${C_0}" "${C_R}stopped${C_0}"; fi
  done
  # Postgres, if that's the backend
  if [ "$(backend)" = postgres ]; then
    if command -v pg_isready >/dev/null 2>&1 && pg_isready -q 2>/dev/null; then
      printf '  %-26s %-18b\n' "postgresql ${C_D}(host)${C_0}" "${C_G}ready${C_0}"
    else
      printf '  %-26s %-18b\n' "postgresql ${C_D}(host)${C_0}" "${C_Y}unknown${C_0}"
    fi
  fi
}

# ── lifecycle ─────────────────────────────────────────────────────────────────
_targets(){ # echo the units to act on, from an optional $1 component
  if [ $# -ge 1 ] && [ -n "${1:-}" ]; then resolve_unit "$1"; else installed_units; fi
}
cmd_lifecycle(){ # $1 verb  $2 optional component
  local verb="$1"; shift
  have_systemd || { echo "No systemd here (container?). Use: docker restart <container>." >&2; exit 1; }
  need_root "$verb"
  local order; mapfile -t order < <(_targets "$@")
  [ "$verb" = stop ] && order=($(printf '%s\n' "${order[@]}" | tac))  # stop in reverse
  local u rc=0
  for u in "${order[@]}"; do
    unit_file "$u" || { warn "$u not installed — skipped"; continue; }
    if systemctl "$verb" "$u.service" 2>/dev/null; then ok "$verb $u"; else fail "$verb $u — see: journalctl -u $u"; rc=1; fi
  done
  return $rc
}
cmd_reload(){
  have_systemd || { echo "Container mode — reload not supported; docker restart." >&2; exit 1; }
  need_root reload
  if nginx -t 2>/dev/null; then systemctl reload nginx && ok "nginx reloaded"; else fail "nginx -t failed — not reloading"; return 1; fi
  is_active remotepower-wsgi && { systemctl restart remotepower-wsgi && ok "app server restarted"; }
}

# ── logs ──────────────────────────────────────────────────────────────────────
cmd_logs(){
  have_systemd || { echo "Container mode — use: docker logs -f <container>." >&2; exit 1; }
  local args=(); local u
  if [ $# -ge 1 ] && [ -n "${1:-}" ]; then args+=(-u "$(resolve_unit "$1").service")
  else for u in $(installed_units); do args+=(-u "$u.service"); done; fi
  exec journalctl -f "${args[@]}"
}

# ── doctor ────────────────────────────────────────────────────────────────────
cmd_doctor(){
  local rc=0 priv=0; am_root && priv=1
  info "${C_B}rp doctor${C_0} — RemotePower $(server_version), backend=$(backend)"
  info ""
  if [ $priv -eq 0 ]; then
    warn "not running as root — the data dir (0700) and nginx config aren't readable,"
    info "       so the backend + nginx checks below are skipped. Re-run: ${C_B}sudo rp doctor${C_0}"
    info ""
  fi

  # 1. code + data dir
  [ -f "$RP_CODE_DIR/cgi-bin/api.py" ] && ok "code present ($RP_CODE_DIR)" || { fail "api.py not found under $RP_CODE_DIR"; rc=1; }
  if [ -d "$RP_DATA_DIR" ]; then
    local perm; perm=$(stat -c '%a' "$RP_DATA_DIR" 2>/dev/null)
    [ "$perm" = 700 ] && ok "data dir $RP_DATA_DIR (mode $perm)" || warn "data dir mode is $perm (expected 700)"
  else fail "data dir $RP_DATA_DIR missing"; rc=1; fi

  # 2. units + ports
  if have_systemd; then
    local u
    for u in "${UNITS[@]}"; do
      unit_file "$u" || { [ "$u" = remotepower-wsgi ] && { fail "$u not installed (the app server)"; rc=1; } || info "  ${C_D}····${C_0} $u not installed (optional)"; continue; }
      if is_active "$u"; then
        local p="${PORT[$u]:-}"
        if [ -n "$p" ] && ! port_open "$p"; then warn "$u active but nothing on :$p"; else ok "$u running"; fi
      else
        [ "$u" = remotepower-wsgi ] && { fail "$u installed but NOT running"; rc=1; } || warn "$u installed but stopped"
      fi
    done
  else
    port_open 8090 && ok "app server reachable (:8090)" || { fail "app server not reachable on :8090"; rc=1; }
  fi

  # 3. storage backend connectivity — the live DB/marker read needs root (0700
  # data dir). Non-root still knows the backend NAME (from rp.env) but can't test
  # connectivity, so report it as skipped rather than run a check that must fail.
  if [ $priv -eq 0 ]; then
    info "  ${C_D}····${C_0} storage backend ($(backend)) — connectivity check needs root (sudo rp doctor)"
  else
  case "$(backend)" in
    postgres)
      if python3 - <<PY 2>/dev/null
import json,sys
sys.path.insert(0, "$RP_CODE_DIR/cgi-bin")
m=json.load(open("$MARKER"))
import storage_pg
dsn=m.get("dsn") or __import__("os").environ.get("RP_PG_DSN")
assert dsn, "no dsn"
storage_pg.configure_dsn(dsn)
d=storage_pg.load("$RP_DATA_DIR/devices.json") or {}
print(len(d))
PY
      then ok "Postgres reachable (marker DSN, $(python3 -c "import json;print(len(json.load(open('$MARKER')).get('dsn','')) and 'dsn set' or 'no dsn')" 2>/dev/null))"
      else fail "Postgres backend selected but the DSN check failed — the push daemon + app can't read devices"; rc=1; fi ;;
    sqlite)  [ -f "$RP_DATA_DIR"/*.db ] 2>/dev/null && ok "SQLite backend" || ok "SQLite backend (marker)" ;;
    json)    ok "JSON file backend" ;;
    unknown) warn "storage backend unknown — the marker is unreadable/corrupt at $MARKER" ;;
  esac
  fi

  # 4. nginx config + routes — needs root (reads the config, certs, log dirs).
  if ! command -v nginx >/dev/null 2>&1; then warn "nginx not found on PATH — skipping config check"
  elif [ $priv -eq 0 ]; then info "  ${C_D}····${C_0} nginx config/routes — skipped (needs root: sudo rp doctor)"
  else
    if nginx -t >/dev/null 2>&1; then ok "nginx config valid (nginx -t)"
    else fail "nginx -t reports errors → run '${C_B}nginx -t${C_0}' to see them; fix, then 'systemctl reload nginx'"; rc=1; fi
    local dump; dump=$(nginx -T 2>/dev/null)
    printf '%s' "$dump" | grep -q 'location = /api/push/connect' \
      && ok "nginx routes /api/push/connect → push daemon" \
      || { unit_file remotepower-push && { warn "push installed but nginx has no /api/push/connect route → add it (see docs/push.md), or 'rp repair'"; }; }
    printf '%s' "$dump" | grep -q 'map \$http_upgrade \$connection_upgrade' \
      || warn "no \$connection_upgrade map — WebSocket (push/webterm) upgrades will fail → add server/conf/remotepower-ws-map.conf to conf.d"
  fi

  # 5. push-daemon specific (the failure class we know bites under Postgres)
  if have_systemd && unit_file remotepower-push && is_active remotepower-push; then
    local pj; pj=$(journalctl -u remotepower-push -n 40 --no-pager 2>/dev/null)
    printf '%s' "$pj" | grep -q 'storage backend detection failed' \
      && { fail "push daemon fell back to flat-file reads (can't find storage/DSN) — under Postgres it rejects every agent"; rc=1; }
    if [ "$(backend)" = postgres ]; then
      printf '%s' "$pj" | grep -q 'backend=postgres' \
        && ok "push daemon on the Postgres backend" \
        || printf '%s' "$pj" | grep -q 'backend=json' && { warn "push daemon reports backend=json under a Postgres install — restart it after this fix"; }
    fi
  fi

  # 6. agent self-update distribution copy
  if [ -f "$RP_CODE_DIR/agent/remotepower-agent" ]; then ok "agent distribution copy present (self-update source)"
  else warn "no $RP_CODE_DIR/agent/remotepower-agent — agent self-update won't serve a binary"; fi

  info ""
  if [ $rc -eq 0 ]; then
    info "${C_G}${C_B}All checks passed.${C_0}"
    [ $priv -eq 0 ] && info "${C_D}(some checks were skipped — run 'sudo rp doctor' for the full picture)${C_0}"
  else
    info "${C_R}${C_B}Some checks FAILED — see above.${C_0}"
    info "Common fixes:  ${C_B}rp restart${C_0} (bounce the stack) · ${C_B}rp repair${C_0} (re-run the"
    info "installer to restore units/routes) · ${C_B}rp logs <component>${C_0} (why a unit is down)."
    info "Full guide: docs/cli.md → Troubleshooting."
  fi
  return $rc
}

# ── tui — live interactive dashboard (k9s/htop style, no dependencies) ────────
_tui_setup(){ printf '\033[?1049h\033[?25l'; }             # alt screen + hide cursor
_tui_teardown(){ printf '\033[?25h\033[?1049l'; }          # restore
_vlen(){ local s; s=$(printf '%s' "$1" | sed $'s/\033\\[[0-9;]*m//g'); printf '%s' "${#s}"; }

cmd_tui(){
  local once=0; [ "${1:-}" = "--once" ] && once=1
  if [ $once -eq 0 ] && { [ ! -t 0 ] || [ ! -t 1 ]; }; then
    echo "rp tui needs an interactive terminal — showing status instead." >&2
    cmd_status; return
  fi
  # richer palette
  local FR=$'\033[38;5;66m' AC=$'\033[38;5;39m' GG=$'\033[38;5;40m' RR=$'\033[38;5;203m'
  local YY=$'\033[38;5;214m' DD=$'\033[38;5;244m' BB=$'\033[1m' ZZ=$'\033[0m'
  local W IN; W=$(tput cols 2>/dev/null || echo 80); [ "$W" -gt 82 ] && W=82; [ "$W" -lt 56 ] && W=56; IN=$((W-2))
  local -a units; mapfile -t units < <(installed_units)
  [ ${#units[@]} -eq 0 ] && units=("${UNITS[@]}")   # show the roster even if none installed yet
  local sel=0 msg="" key rest

  _dash(){ printf '─%.0s' $(seq 1 "$1"); }
  # pad a possibly-colored string to visible width $2
  _pad(){ local s="$1" w="$2" v n; v=$(_vlen "$s"); n=$((w - v)); [ $n -lt 0 ] && n=0; printf '%s%*s' "$s" "$n" ""; }
  _edge(){ # $1=corner-left $2=corner-right  $3=optional title ; \033[K erases stale tail
    if [ -n "${3:-}" ]; then
      local t=" $3 " r; r=$((IN - ${#t} - 1)); [ $r -lt 0 ] && r=0
      printf '%s%s─%s%s%s%s%s\033[K\n' "$FR" "$1" "$BB$t$ZZ$FR" "$(_dash $r)" "$FR" "$2" "$ZZ"
    else printf '%s%s%s%s%s\033[K\n' "$FR" "$1" "$(_dash $IN)" "$2" "$ZZ"; fi
  }
  _row(){ local c="$1" v; v=$(_vlen "$c")   # truncate (plain) if it would overflow the frame
          if [ "$v" -gt "$IN" ]; then c=$(printf '%s' "$c" | sed $'s/\033\\[[0-9;]*m//g'); c="${c:0:$((IN-1))}…"; fi
          printf '%s│%s%s%s│%s\033[K\n' "$FR" "$ZZ" "$(_pad "$c" $IN)" "$FR" "$ZZ"; }
  _sep(){ printf '%s├%s┤%s\033[K\n' "$FR" "$(_dash $IN)" "$ZZ"; }

  _draw(){
    local host ver be up load
    host=$(hostname -s 2>/dev/null || hostname); ver=$(server_version); be=$(backend)
    up=$(awk '{d=int($1/86400);h=int($1%86400/3600);m=int($1%3600/60);if(d)printf "%dd %dh",d,h;else if(h)printf "%dh %dm",h,m;else printf "%dm",m}' /proc/uptime 2>/dev/null); up=${up:-?}
    load=$(cut -d' ' -f1 /proc/loadavg 2>/dev/null); load=${load:-?}
    printf '\033[H'   # home
    _edge '╭' '╮' "RemotePower  ·  $host"
    _row "  ${DD}version${ZZ} ${BB}$ver${ZZ}    ${DD}backend${ZZ} $be    ${DD}uptime${ZZ} $up    ${DD}load${ZZ} $load"
    _sep
    _row "  ${DD}COMPONENT             STATUS        BOOT       PORT${ZZ}"
    local i u name statecol stateword boot port dot pointer nrun=0 nstop=0 nfail=0
    for i in "${!units[@]}"; do
      u="${units[$i]}"; name="${u#remotepower-}"
      if have_systemd && unit_file "$u"; then
        if systemctl is-failed --quiet "$u.service" 2>/dev/null; then dot="${RR}✖${ZZ}"; stateword="${RR}failed${ZZ}"; nfail=$((nfail+1))
        elif is_active "$u"; then dot="${GG}●${ZZ}"; stateword="${GG}running${ZZ}"; nrun=$((nrun+1))
        else dot="${DD}○${ZZ}"; stateword="${DD}stopped${ZZ}"; nstop=$((nstop+1)); fi
        is_enabled "$u" && boot="enabled " || boot="${YY}disabled${ZZ}"
      else dot="${DD}·${ZZ}"; stateword="${DD}absent${ZZ}"; boot="${DD}—${ZZ}"; nstop=$((nstop+0)); fi
      local p="${PORT[$u]:-}"; port="—       "
      if [ -n "$p" ]; then port_open "$p" && port="${GG}:$p ✓${ZZ}" || port="${RR}:$p ✗${ZZ}"; fi
      if [ "$i" -eq "$sel" ]; then pointer="${AC}▸${ZZ}"; name="${AC}${BB}${name}${ZZ}"; else pointer=" "; fi
      _row " $pointer $dot $(_pad "$name" 18) $(_pad "$stateword" 11) $(_pad "$boot" 9) $port"
    done
    _sep
    _row "  ${GG}● $nrun running${ZZ}   ${DD}○ $nstop stopped${ZZ}   ${RR}✖ $nfail failed${ZZ}${msg:+     $msg}"
    _edge '╰' '╯' ""
    printf '%s  ↑/↓%s select  %s[r]%sestart %s[s]%start %s[x]%stop  %s[d]%soctor %s[l]%sogs %s[P]%srepair  %s[?]%shelp %s[q]%suit%s\033[K\n' \
      "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$AC" "$ZZ" "$ZZ"
    printf '\033[K\033[J'   # erase to EOL + clear below (kills stale frame tails)
  }
  _help(){ cat <<H

  rp tui — keys
    ↑/↓ or j/k   move the selection            d   run 'rp doctor'
    r            restart the selected unit      l   logs for the selected unit
    s / x        start / stop the unit          P   repair (re-deploy / restart+reload)
    q            quit                           ?   this help
  Actions use sudo when you aren't root (you may be prompted for a password).

  Troubleshooting — what a doctor failure means and how to fix it
    "not running as root"        → run: sudo rp doctor   (reads the 0700 data dir + nginx)
    a unit "installed but NOT running"
                                 → rp logs <name> to see why, then: sudo rp restart <name>
    "nginx -t reports errors"    → run 'nginx -t' as root, fix the file, systemctl reload nginx
    "no /api/push/connect route" / "no \$connection_upgrade map"
                                 → your nginx is missing the push route; run 'rp repair', or add
                                   the block + map from docs/push.md to your vhost
    "push daemon ... backend=json under Postgres" / "storage backend detection failed"
                                 → the push daemon can't read the DB; sudo rp restart push, then
                                   re-check. If it persists, the storage marker/DSN is unreadable.
    "Postgres ... DSN check failed"
                                 → the marker has no/invalid dsn; the app can't reach the DB either.
    stack broadly wedged after an update
                                 → rp repair  (re-runs deploy-server.sh: units, binaries, restart)

  Full reference: docs/cli.md   ·   press q to return
H
  }

  _sudo(){ if [ "$(id -u)" = 0 ]; then "$@"; elif command -v sudo >/dev/null 2>&1; then sudo "$@"; else return 90; fi; }
  _act(){ # $1 verb on the selected unit
    local u="${units[$sel]}"
    have_systemd && unit_file "$u" || { msg="${YY}$u not installed${ZZ}"; return; }
    msg="${DD}${1}ing ${u#remotepower-}…${ZZ}"; _draw
    if _sudo systemctl "$1" "$u.service" >/dev/null 2>&1; then msg="${GG}$1 ${u#remotepower-} ✓${ZZ}"
    elif [ $? -eq 90 ]; then msg="${RR}need root — run rp as sudo${ZZ}"
    else msg="${RR}$1 ${u#remotepower-} failed${ZZ}"; fi
  }
  _pager(){ if command -v less >/dev/null 2>&1; then less -R; else cat; fi; }

  if [ $once -eq 1 ]; then _draw; return 0; fi
  trap '_tui_teardown; exit 0' INT TERM
  _tui_setup; printf '\033[2J'
  while :; do
    _draw
    IFS= read -rsn1 -t 2 key || { msg=""; continue; }
    case "$key" in
      $'\033') read -rsn2 -t 0.05 rest || rest=''
               case "$rest" in '[A') sel=$(( (sel-1+${#units[@]}) % ${#units[@]} ));;
                                '[B') sel=$(( (sel+1) % ${#units[@]} ));; esac ;;
      k|K) sel=$(( (sel-1+${#units[@]}) % ${#units[@]} )) ;;
      j|J) sel=$(( (sel+1) % ${#units[@]} )) ;;
      r|R) _act restart ;;
      s|S) _act start ;;
      x|X) _act stop ;;
      d|D) _tui_teardown; { cmd_doctor; echo; echo "── press q to return ──"; } | _pager; _tui_setup; printf '\033[2J' ;;
      l|L) _tui_teardown; { have_systemd && journalctl -u "${units[$sel]}.service" -n 300 --no-pager 2>/dev/null || echo "no logs"; } | _pager; _tui_setup; printf '\033[2J' ;;
      '?'|h|H) _tui_teardown; _help | _pager; _tui_setup; printf '\033[2J' ;;
      p|P) _tui_teardown; printf '\033[?25h'; echo "Repairing (rp repair)…"; cmd_repair; echo; echo "── press ENTER to return ──"; read -r _; _tui_setup; printf '\033[2J' ;;
      g|G) msg="${DD}refreshed${ZZ}" ;;
      q|Q) break ;;
    esac
  done
  _tui_teardown
}

# ── install / deploy / repair — run the setup scripts from the source checkout ─
_src_dir(){  # where install-server.sh / deploy-server.sh live (NOT the web root)
  local d="${RP_SRC:-}"
  [ -z "$d" ] && [ -r /etc/remotepower/rp.env ] && d=$(. /etc/remotepower/rp.env 2>/dev/null; printf '%s' "${RP_SRC:-}")
  [ -n "$d" ] && [ -f "$d/install-server.sh" ] && { printf '%s' "$d"; return 0; }
  local c; for c in "${HOME:-/root}/claude-code-ent" /opt/remotepower/src /usr/src/remotepower; do
    [ -f "$c/install-server.sh" ] && { printf '%s' "$c"; return 0; }
  done
  return 1
}
_run_script(){  # $1 = script filename in the checkout; rest = its args
  local src; src=$(_src_dir) || { echo "rp: can't find the RemotePower source checkout." >&2
    echo "    Set RP_SRC=/path/to/checkout (the installers record it in /etc/remotepower/rp.env)." >&2; return 1; }
  local script="$src/$1"; shift
  [ -f "$script" ] || { echo "rp: $script not found in $src." >&2; return 1; }
  echo "→ ${C_B}$script${C_0} $*"
  if am_root; then bash "$script" "$@"
  elif command -v sudo >/dev/null 2>&1; then sudo bash "$script" "$@"
  else echo "rp: this needs root and sudo isn't available." >&2; return 1; fi
}
cmd_install(){ _run_script install-server.sh "$@"; }   # fresh install / re-run the wizard
cmd_deploy(){  _run_script deploy-server.sh  "$@"; }    # update code + units + restart
cmd_repair(){                                           # make everything current again
  if _src_dir >/dev/null 2>&1; then _run_script deploy-server.sh "$@"
  else
    have_systemd || { echo "container mode — use docker restart / rebuild." >&2; return 1; }
    echo "→ no source checkout found; in-place repair (restart the stack + reload nginx)"
    cmd_lifecycle restart
    am_root && nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null && echo "nginx reloaded" || true
  fi
}

usage(){ awk 'NR<3{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0"; }

# ── dispatch ──────────────────────────────────────────────────────────────────
cmd="${1:-status}"; shift || true
case "$cmd" in
  status|st)        cmd_status "$@" ;;
  tui|top|dash|dashboard|ui) cmd_tui "$@" ;;
  start)            cmd_lifecycle start "$@" ;;
  stop)             cmd_lifecycle stop "$@" ;;
  restart|re)       cmd_lifecycle restart "$@" ;;
  reload)           cmd_reload "$@" ;;
  doctor|diag|dr)   cmd_doctor "$@" ;;
  logs|log)         cmd_logs "$@" ;;
  install|setup)    cmd_install "$@" ;;
  deploy|update)    cmd_deploy "$@" ;;
  repair|fix)       cmd_repair "$@" ;;
  version|-v|--version) info "RemotePower $(server_version)" ;;
  help|-h|--help)   usage ;;
  *) echo "rp: unknown command '$cmd' (try: rp help)" >&2; exit 2 ;;
esac
