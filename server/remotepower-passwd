#!/usr/bin/env python3
"""remotepower-passwd — Change the admin password for RemotePower"""
import json, hashlib, getpass, sys
from pathlib import Path

USERS_FILE = Path('/var/lib/remotepower/users.json')

if not USERS_FILE.exists():
    print("Error: users file not found. Is the server installed?")
    sys.exit(1)

users = json.loads(USERS_FILE.read_text())
print("Change RemotePower password")
print()

username = input(f"Username [{', '.join(users.keys())}]: ").strip()
if username not in users:
    print(f"User '{username}' not found.")
    sys.exit(1)

pw = getpass.getpass("New password: ")
pw2 = getpass.getpass("Confirm password: ")
if pw != pw2:
    print("Passwords don't match.")
    sys.exit(1)

users[username]['password_hash'] = hashlib.sha256(pw.encode()).hexdigest()
USERS_FILE.write_text(json.dumps(users, indent=2))
print(f"Password updated for '{username}'.")
