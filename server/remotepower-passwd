#!/usr/bin/env python3
"""remotepower-passwd — Manage admin users for RemotePower"""

import json
import hashlib
import getpass
import secrets
import sys
import time
import re
from pathlib import Path

USERS_FILE = Path('/var/lib/remotepower/users.json')

try:
    import bcrypt as _bcrypt
    _BCRYPT = True
except ImportError:
    _BCRYPT = False

# Iterations match api.py's _PBKDF2_ITERATIONS (OWASP floor for PBKDF2-SHA256).
_PBKDF2_ITERATIONS = 600_000

def hash_password(plain: str) -> str:
    if _BCRYPT:
        return _bcrypt.hashpw(plain.encode(), _bcrypt.gensalt(12)).decode()
    # No bcrypt: salted PBKDF2-HMAC-SHA256 in the exact self-describing format
    # api.py's verify_password understands — NOT bare unsalted SHA-256 (which is
    # fast and rainbow-table-able). Pure stdlib, no extra dependency.
    print("Warning: bcrypt not installed, using salted PBKDF2-HMAC-SHA256.")
    print("         For bcrypt instead: pip3 install bcrypt")
    salt = secrets.token_bytes(16)
    dk = hashlib.pbkdf2_hmac('sha256', plain.encode(), salt, _PBKDF2_ITERATIONS)
    return f'pbkdf2${_PBKDF2_ITERATIONS}${salt.hex()}${dk.hex()}'

def hash_type(stored: str) -> str:
    if stored.startswith('$2'):
        return 'bcrypt'
    if stored.startswith('pbkdf2$'):
        return 'pbkdf2'
    return 'sha256'    # legacy pre-2.3.2 hashes (still verified by the server)

if not USERS_FILE.exists():
    print("Error: users file not found. Is the server installed?")
    sys.exit(1)

def load():
    return json.loads(USERS_FILE.read_text())

def save(users):
    USERS_FILE.write_text(json.dumps(users, indent=2))

def cmd_change():
    users = load()
    if not users:
        print("No users exist yet. Use 'Add user' first.")
        sys.exit(1)
    # v2.2.6: the prompt used to show [user1, user2] as a hint but
    # pressing Enter passed an empty string — "User '' not found".
    # Now: with exactly one user, Enter defaults to it (the bracket
    # really is a default). With several, Enter re-prompts rather
    # than erroring out.
    user_list = list(users.keys())
    default = user_list[0] if len(user_list) == 1 else None
    while True:
        prompt = (f"Username [{default}]: " if default
                  else f"Username ({', '.join(user_list)}): ")
        username = input(prompt).strip()
        if not username and default:
            username = default
        if not username:
            print("Please enter a username.")
            continue
        break
    if username not in users:
        print(f"User '{username}' not found.")
        sys.exit(1)
    while True:
        pw  = getpass.getpass("New password: ")
        pw2 = getpass.getpass("Confirm:      ")
        if pw == pw2:
            break
        print("Passwords don't match, try again.")
    users[username]['password_hash'] = hash_password(pw)
    save(users)
    print(f"Password updated for '{username}' ({hash_type(users[username]['password_hash'])}).")

def cmd_add():
    users = load()
    username = input("New username: ").strip()
    if not username or not re.match(r'^[a-zA-Z0-9_\-]{2,32}$', username):
        print("Invalid username.")
        sys.exit(1)
    if username in users:
        print(f"User '{username}' already exists. Use option 1 to change password.")
        sys.exit(1)
    while True:
        pw  = getpass.getpass("Password: ")
        pw2 = getpass.getpass("Confirm:  ")
        if pw == pw2:
            break
        print("Passwords don't match, try again.")
    users[username] = {'password_hash': hash_password(pw), 'created': int(time.time())}
    save(users)
    print(f"User '{username}' created.")

def cmd_delete():
    users = load()
    if len(users) <= 1:
        print("Cannot delete the last admin user.")
        sys.exit(1)
    username = input(f"Delete username [{', '.join(users.keys())}]: ").strip()
    if username not in users:
        print(f"User '{username}' not found.")
        sys.exit(1)
    confirm = input(f"Delete '{username}'? [y/N]: ").strip().lower()
    if confirm == 'y':
        del users[username]
        save(users)
        print(f"User '{username}' deleted.")
    else:
        print("Aborted.")

def cmd_list():
    users = load()
    print(f"\n{'Username':<20} {'Hash type':<10} {'Created'}")
    print("─" * 55)
    for u, d in users.items():
        ht = hash_type(d.get('password_hash', ''))
        ts = time.strftime('%Y-%m-%d', time.localtime(d.get('created', 0)))
        print(f"  {u:<18} {ht:<10} {ts}")
    print()

def main():
    print("\nRemotePower — user management")
    print("1) Change password")
    print("2) Add user")
    print("3) Delete user")
    print("4) List users")
    print("q) Quit")
    choice = input("> ").strip().lower()

    if choice == '1':
        cmd_change()
    elif choice == '2':
        cmd_add()
    elif choice == '3':
        cmd_delete()
    elif choice == '4':
        cmd_list()
    elif choice in ('q', ''):
        pass
    else:
        print("Unknown option.")

if __name__ == '__main__':
    main()
