#!/usr/bin/env python3
"""RemotePower TLS expiry probe — cron runner.

Run periodically (suggested: every 6 hours) from systemd timer or cron.
Probes every host in ``tls_targets.json``, writes the latest result to
``tls_results.json``, and emits webhook notifications for hosts that
crossed a warn/critical threshold since the last run.

Designed to be safe to run alongside the CGI: writes are atomic (the
shared ``save()`` helper writes to a tempfile + rename) and the data
files are short enough that a partial overwrite isn't a concern.

Exit code: 0 always (don't spam cron mail on transient probe failures).
Use journalctl / the audit log to diagnose persistent failures.

Usage:
    /usr/bin/python3 /var/www/remotepower/cgi-bin/remotepower-tls-check

Cron / systemd:
    Add a ``remotepower-tls-check.service`` and ``.timer`` pair, or a
    line in /etc/cron.d/remotepower::

        0 */6 * * * www-data /var/www/remotepower/cgi-bin/remotepower-tls-check
"""
from __future__ import annotations

import json
import os
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

import tls_monitor  # noqa: E402

DATA_DIR = Path(os.environ.get("RP_DATA_DIR", "/var/lib/remotepower"))
TARGETS  = DATA_DIR / "tls_targets.json"
RESULTS  = DATA_DIR / "tls_results.json"

# Thresholds for the combined tls_expiry webhook event.
WARN_DAYS = 30   # warning severity
CRIT_DAYS = 7    # critical severity


def _load(p: Path) -> dict:
    if not p.exists():
        return {}
    try:
        with p.open() as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (json.JSONDecodeError, OSError):
        return {}


def _save(p: Path, data: dict) -> None:
    """Atomic write — same shape as the CGI's save() helper."""
    p.parent.mkdir(parents=True, exist_ok=True)
    tmp = p.with_suffix(p.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2))
    tmp.replace(p)


def _fire_tls_webhook(target: dict, days_left: int, severity: str) -> None:
    """Call the RemotePower CGI to fire a tls_expiry webhook.

    We POST to /api/internal/tls-webhook — a small internal endpoint that
    validates the request comes from localhost and calls fire_webhook().
    If that endpoint isn't available (older server), we fall back to
    importing api directly so the cron always works.
    """
    try:
        # Preferred: loopback HTTP so the CGI handles all the delivery logic.
        import urllib.request, urllib.error
        server_url = os.environ.get('RP_SERVER_URL', 'http://127.0.0.1')
        payload = json.dumps({
            'host':      target.get('host', ''),
            'port':      target.get('port', 443),
            'days_left': days_left,
            'severity':  severity,
        }).encode()
        req = urllib.request.Request(
            f'{server_url}/api/internal/tls-webhook',
            data=payload,
            headers={'Content-Type': 'application/json',
                     'X-Remotepower-Internal': '1'},
            method='POST',
        )
        urllib.request.urlopen(req, timeout=10)
    except Exception as exc:
        print(f"[tls-check] webhook delivery failed: {exc}", file=sys.stderr)


def main() -> int:
    targets = _load(TARGETS)
    if not targets:
        print(f"[tls-check] no targets configured at {TARGETS}", file=sys.stderr)
        return 0

    started = time.time()
    print(f"[tls-check] probing {len(targets)} target(s)...")
    results  = tls_monitor.probe_all(targets)

    # Edge-triggered webhook firing: read previous results to detect crossings.
    prev_results = _load(RESULTS)
    now = int(time.time())

    issues = []
    for tid, t in targets.items():
        r    = results.get(tid, {})
        prev = prev_results.get(tid, {})

        days      = tls_monitor.days_until_expiry(r)
        prev_days = tls_monitor.days_until_expiry(prev) if prev else 9999

        host = t.get('host', '?')
        port = t.get('port', 443)

        # Determine severity bracket
        if days <= CRIT_DAYS:
            sev = 'critical'
        elif days <= WARN_DAYS:
            sev = 'warning'
        else:
            sev = None

        # Crossed a threshold since last check → fire webhook once
        if sev and prev_days > CRIT_DAYS and days <= CRIT_DAYS:
            _fire_tls_webhook(t, days, 'critical')
        elif sev == 'warning' and prev_days > WARN_DAYS and days <= WARN_DAYS:
            _fire_tls_webhook(t, days, 'warning')

        # DANE failure (any check run that fails)
        dane_ok_prev = prev.get('dane_status', 'ok') in ('ok', 'not_checked', None, '')
        dane_ok_now  = r.get('dane_status', 'ok') in ('ok', 'not_checked', None, '')
        if not dane_ok_now and dane_ok_prev:
            _fire_tls_webhook(t, days, 'warning')

        if sev in ('critical', 'warning'):
            err = r.get('dns_error') or r.get('tls_error') or ''
            issues.append(f"  {sev.upper():8s} {host}:{port:<6} {err or f'{days}d left'}")

    _save(RESULTS, results)

    if issues:
        print(f"[tls-check] {len(issues)} issue(s):")
        print('\n'.join(issues))
    print(f"[tls-check] done in {time.time() - started:.1f}s")
    return 0


if __name__ == "__main__":
    sys.exit(main())
