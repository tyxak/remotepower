	optdepends = wireguard-go: WG Access road-warrior VPN hub (Admin -> WG Access)
	optdepends = wireguard-tools: WG Access — wg/wg-quick used by the VPN hub helper
	optdepends = gunicorn: persistent WSGI app tier (remotepower-wsgi.service, large fleets)
	optdepends = postgresql: PostgreSQL storage backend for large / multi-node fleets
	backup = etc/nginx/snippets/remotepower-locations.conf
