pkgbase = remotepower-server
	pkgdesc = Self-hosted fleet-management server for RemotePower (nginx + Python CGI): dashboards, CVE/drift/compliance, monitoring, AI
	pkgver = 6.0.0
	pkgrel = 1
	url = https://github.com/tyxak/remotepower
	install = remotepower-server.install
	arch = any
	license = MIT
	depends = nginx
	depends = fcgiwrap
	depends = python
	depends = python-bcrypt
	depends = python-cryptography
	depends = python-dnspython
	depends = iputils
	optdepends = python-reportlab: PDF report export
	optdepends = python-webauthn: passkey / WebAuthn MFA (AUR)
	optdepends = python-pysaml2: SAML SSO (AUR)
	optdepends = xmlsec: SAML signature verification (pairs with python-pysaml2)
	optdepends = wireguard-go: WG Access road-warrior VPN hub (Admin -> WG Access)
	optdepends = wireguard-tools: WG Access — wg/wg-quick used by the VPN hub helper
	optdepends = gunicorn: persistent WSGI app tier (remotepower-wsgi.service, large fleets)
	optdepends = postgresql: PostgreSQL storage backend for large / multi-node fleets
	backup = etc/nginx/snippets/remotepower-locations.conf
