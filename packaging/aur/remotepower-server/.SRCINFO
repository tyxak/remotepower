pkgbase = remotepower-server
	pkgdesc = Self-hosted fleet-management server for RemotePower (nginx + Python CGI): dashboards, CVE/drift/compliance, monitoring, AI
	pkgver = 5.5.0
	pkgrel = 1
	url = https://github.com/tyxak/remotepower
	install = remotepower-server.install
	arch = any
	license = MIT
	depends = nginx
	depends = fcgiwrap
	depends = python
	depends = python-bcrypt
	depends = python-cryptography
	depends = python-dnspython
	optdepends = python-reportlab: PDF report export
	optdepends = python-webauthn: passkey / WebAuthn MFA (AUR)
	optdepends = python-pysaml2: SAML SSO (AUR)
