      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "RemotePower fleet overview \u2014 built against the /api/metrics Prometheus exposition (status-token auth). Ships with RemotePower (contrib/grafana).",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
